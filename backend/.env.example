# Server
PORT=8080
ENV=development

# Neon PostgreSQL (include sslmode=require)
DATABASE_URL=postgresql://user:password@ep-xxx.region.aws.neon.tech/rozy?sslmode=require

# Redis (Upstash or local)
REDIS_URL=redis://localhost:6379

# JWT
JWT_SECRET=change-me-in-production

# Mapbox
MAPBOX_ACCESS_TOKEN=

# Object storage (R2/S3)
STORAGE_BUCKET=rozy-docs
STORAGE_ENDPOINT=
STORAGE_ACCESS_KEY=
STORAGE_SECRET_KEY=

# Firebase (FCM)
FCM_PROJECT_ID=
FCM_CREDENTIALS_JSON=

# MTN MoMo
MTN_MOMO_SUBSCRIPTION_KEY=
MTN_MOMO_API_USER=
MTN_MOMO_API_KEY=
MTN_MOMO_WEBHOOK_SECRET=

# Airtel Money
AIRTEL_CLIENT_ID=
AIRTEL_CLIENT_SECRET=
AIRTEL_WEBHOOK_SECRET=

# OTP (dev: log to console)
SMS_PROVIDER=console

# Run SQL migrations automatically on API startup
AUTO_MIGRATE=true
